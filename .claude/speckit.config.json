{
  "version": "1.0",
  "git": {
    "autoCreateBranch": false,
    "autoCommit": false,
    "autoSwitch": false,
    "autoPush": false,
    "requireApproval": true
  },
  "specs": {
    "location": "specs/",
    "numberingFormat": "001-{slug}",
    "templatesPath": ".specify/templates/",
    "useTemplates": true
  },
  "scripts": {
    "enabled": true,
    "path": ".specify/scripts/bash/"
  },
  "workflow": {
    "manualGitOps": true,
    "preserveStructure": true
  }
}
